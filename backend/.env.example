# ══════════════════════════════════════════════════════════
#  WORKLY — Variables de entorno backend
#  Copia este archivo como .env y rellena los valores reales
# ══════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production

# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── Base de datos MySQL ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=workly_db

# Tamaño del pool de conexiones (opcional, default: 10)
DB_CONNECTION_LIMIT=10

# ── JWT ───────────────────────────────────────────────────
# IMPORTANTE: usa strings largos y aleatorios en producción
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_secreto_largo_y_aleatorio
JWT_REFRESH_SECRET=otro_string_diferente_igual_de_largo_y_secreto

# Expiración del access token (30m recomendado)
JWT_EXPIRES_IN=30m

# Expiración del refresh token (7d recomendado)
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────
# URL del frontend (sin barra final)
FRONTEND_URL=http://localhost:5173
# En producción: FRONTEND_URL=https://tudominio.com

# ── Email (Resend) ────────────────────────────────────────
# Necesario para envío de facturas por email
# Obtener en: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Workly <noreply@tudominio.com>

# ── Rate limiting ─────────────────────────────────────────
# Peticiones máximas por IP en 15 minutos (ventana general)
RATE_LIMIT_MAX=500
# Intentos de auth máximos por IP en 15 minutos
RATE_LIMIT_AUTH_MAX=20